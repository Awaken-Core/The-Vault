generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  DISPUTED
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  emailVerified    Boolean          @default(false)
  password         String?
  image            String?
  isBanned         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  role             Role             @default(USER)
  polarCustomerId  String?          @unique
  sessions         Session[]
  productPurchases ProductPurchase[]
  servicePurchases ServicePurchase[]
  quotations       Quotation[]
  invitations      Invitation[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// One-time payment for products — no installments
model ProductPurchase {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  polarOrderId String?        @unique
  amount       Decimal        @db.Decimal(12, 2)
  currency     String         @default("usd")
  status       PurchaseStatus @default(PENDING)
  products     Product[]
  quotation    Quotation?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@map("product_purchase")
}

// Service engagement (web dev, design, etc.) — supports installments
model ServicePurchase {
  id               String                      @id @default(uuid())
  userId           String
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  polarOrderId     String?                     @unique
  amount           Decimal                     @db.Decimal(12, 2)
  currency         String                      @default("usd")
  status           PurchaseStatus              @default(PENDING)
  installmentCount Int                         @default(1)
  services         Service[]
  installments     ServicePurchaseInstallment[]
  quotation        Quotation?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([userId])
  @@map("service_purchase")
}

model ServicePurchaseInstallment {
  id                String            @id @default(uuid())
  servicePurchaseId String
  servicePurchase   ServicePurchase   @relation(fields: [servicePurchaseId], references: [id], onDelete: Cascade)
  number            Int
  amount            Decimal           @db.Decimal(12, 2)
  dueDate           DateTime
  paidAt            DateTime?
  status            InstallmentStatus @default(PENDING)
  polarOrderId      String?           @unique

  @@unique([servicePurchaseId, number])
  @@index([servicePurchaseId])
  @@map("service_purchase_installment")
}

// One-time payment template; price is required
model Product {
  id               String            @id @default(uuid())
  name             String
  description      String?
  price            Decimal           @db.Decimal(12, 2)
  polarProductId   String?           @unique
  productPurchases ProductPurchase[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("product")
}

// Type of work (web dev, design, etc.)
model Service {
  id               String            @id @default(uuid())
  name             String
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  servicePurchases ServicePurchase[]

  @@map("service")
}

model Quotation {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  productPurchaseId String?         @unique
  productPurchase   ProductPurchase? @relation(fields: [productPurchaseId], references: [id])
  servicePurchaseId String?         @unique
  servicePurchase   ServicePurchase? @relation(fields: [servicePurchaseId], references: [id])
  status            QuotationStatus @default(DRAFT)
  documentUrl       String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("quotation")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  invitedBy String
  inviter   User     @relation(fields: [invitedBy], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invitation")
}

model RequestInvitation {
  id        String   @id @default(uuid())
  email     String
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("request_invitation")
}
